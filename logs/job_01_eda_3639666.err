# ── Export: Canton DO Ranking (input for notebook 09) ────────────────────────
# Uses daily_data already loaded above. Keys are int gauge IDs.
# Saves results/canton_do_ranking.csv

GAUGE_CANTON = {
    2009:'VS', 2011:'BE', 2016:'AG', 2018:'BE', 2033:'BE', 2044:'ZH',
    2068:'TI', 2084:'SO', 2085:'BE', 2099:'ZH', 2109:'TG', 2143:'TG',
    2161:'TG', 2167:'SG', 2174:'GE', 2176:'ZH', 2181:'ZH', 2256:'LU',
    2290:'LU', 2347:'FR', 2369:'FR', 2374:'VD', 2392:'GE', 2410:'ZH',
    2415:'GR', 2457:'GR', 2462:'VS', 2473:'BE', 2485:'NE', 2604:'JU',
    2613:'BL', 2617:'BS', 2635:'SH',
}

gauge_rows = []
for gid, df in daily_data.items():
    if 'O2C_sensor' not in df.columns:
        continue
    do = df['O2C_sensor'].dropna()
    if len(do) < 100:
        continue
    canton = GAUGE_CANTON.get(int(gid), 'UNK')
    if canton == 'UNK':
        continue
    gauge_rows.append({
        'gauge_id': int(gid),
        'canton': canton,
        'n_valid_do': len(do),
        'do_mean': round(float(do.mean()), 4),
        'do_min': round(float(do.min()), 4),
        'n_lt4': int((do < 4).sum()),
        'n_lt6': int((do < 6).sum()),
        'n_lt8': int((do < 8).sum()),
        'pct_lt4': round(float((do < 4).mean() * 100), 4),
        'pct_lt6': round(float((do < 6).mean() * 100), 4),
        'pct_lt8': round(float((do < 8).mean() * 100), 4),
    })

print(f"Gauges with canton mapping: {len(gauge_rows)} / {len(daily_data)}")

gauge_df = pd.DataFrame(gauge_rows)
canton_df = gauge_df.groupby('canton', as_index=False).agg(
    n_gauges=('gauge_id', 'count'),
    total_do_days=('n_valid_do', 'sum'),
    mean_do_mean=('do_mean', 'mean'),
    worst_do_min=('do_min', 'min'),
    total_breach_4=('n_lt4', 'sum'),
    total_breach_6=('n_lt6', 'sum'),
    total_breach_8=('n_lt8', 'sum'),
    overall_pct_4=('pct_lt4', 'mean'),
    overall_pct_6=('pct_lt6', 'mean'),
    overall_pct_8=('pct_lt8', 'mean'),
    mean_pct_below_4=('pct_lt4', 'mean'),
    mean_pct_below_6=('pct_lt6', 'mean'),
    mean_pct_below_8=('pct_lt8', 'mean'),
)
canton_df = canton_df.sort_values('overall_pct_8', ascending=False).reset_index(drop=True)
canton_df.insert(0, 'rank', range(1, len(canton_df) + 1))

RESULTS_DIR.mkdir(exist_ok=True)
canton_df.to_csv(RESULTS_DIR / 'canton_do_ranking.csv', index=False)
print(f"Saved canton_do_ranking.csv: {len(canton_df)} cantons")
print(canton_df[['rank', 'canton', 'n_gauges', 'overall_pct_8', 'mean_do_mean']].to_string(index=False))

